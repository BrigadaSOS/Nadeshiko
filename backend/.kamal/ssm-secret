#!/usr/bin/env bash
set -euo pipefail

destination="${1:?Usage: .kamal/ssm-secret DESTINATION SECRET_NAME}"
secret_name="${2:?Usage: .kamal/ssm-secret DESTINATION SECRET_NAME}"
region="${AWS_REGION:-eu-north-1}"
parameter_name="/nadeshiko/${destination}/${secret_name}"

case "$destination" in
  prod|staging)
    profile="nadeshiko-${destination}"
    ;;
  shared)
    profile="nadeshiko-prod"
    ;;
  *)
    echo "Unknown Kamal destination for SSM secret: $destination" >&2
    exit 1
    ;;
esac

aws_args=(--region "$region")

if [[ -z "${AWS_ACCESS_KEY_ID:-}" && -z "${AWS_WEB_IDENTITY_TOKEN_FILE:-}" ]]; then
  aws_args=(--profile "$profile" "${aws_args[@]}")

  if ! aws "${aws_args[@]}" sts get-caller-identity >/dev/null 2>&1; then
    echo "AWS SSO credentials unavailable for $profile; running aws sso login --profile $profile" >&2
    aws sso login --profile "$profile" >&2
  fi
fi

if ! value=$(aws "${aws_args[@]}" ssm get-parameter --with-decryption --name "$parameter_name" --query 'Parameter.Value' --output text); then
  echo "Failed to read SSM parameter: $parameter_name" >&2
  exit 1
fi

if [[ -z "$value" || "$value" == "None" ]]; then
  echo "Blank SSM parameter: $parameter_name" >&2
  exit 1
fi

printf '%s' "$value"
