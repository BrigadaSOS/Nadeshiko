{
  "name": "backend",
  "version": "1.4.3",
  "description": "",
  "main": "main.ts",
  "type": "module",
  "scripts": {
    "setup": "bun run bin/setup.ts",
    "dev": "bun run generate:api && bun run bin/generateErrorProfiles.ts && bun --hot main.ts | pino-pretty",
    "build": "bun run generate:api && bun run bin/generateErrorProfiles.ts && bun build ./main.ts --outdir ./prod --target bun",
    "start": "bun prod/main.js",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint:openapi && bun run lint && bun run typecheck && bun run build",
    "lint": "biome lint .",
    "lint:openapi": "redocly lint",
    "lint:openapi:bundled": "bun run docs:bundle && redocly lint docs/generated/openapi.yaml --skip-rule no-unused-components",
    "lint:fix": "biome lint . --write",
    "format": "biome format . --write",
    "generate:api": "rm -rf generated && bun run docs:bundle && openapi-code-generator --input ./docs/generated/openapi.yaml --input-type openapi3 --output ./generated --template typescript-express --schema-builder zod-v3 --grouping-strategy first-tag && bun run bin/generateOutputTypes.ts",
    "generate:bruno": "bun run docs:bundle && bun run bin/generateBrunoCollection.ts",
    "generate:all": "bun run docs:bundle && bun run generate:api && bun run bin/generateErrorProfiles.ts && bun run generate:bruno",
    "docs:bundle": "redocly bundle main -o ./docs/generated/openapi.yaml --remove-unused-components",
    "docs:serve": "bun run docs:bundle && chokidar 'docs/openapi/**/*.yaml' -c 'bun run docs:bundle' & scalar document serve -w docs/generated/openapi.yaml",
    "db:migrate": "bun run bin/db.ts migrate",
    "db:bootstrap": "bun run bin/dbBootstrap.ts",
    "db:rollback": "bun run bin/db.ts rollback",
    "db:seed": "bun run bin/db.ts seed",
    "db:setup": "bun run bin/db.ts setup",
    "db:reset": "bun run bin/db.ts reset",
    "db:prepare": "bun run bin/db.ts prepare",
    "db:drop": "bun run bin/db.ts drop",
    "db:status": "bun run bin/db.ts status",
    "es:reindex": "bun run bin/es.ts reindex",
    "es:status": "bun run bin/es.ts status",
    "routes": "bun run bin/routes.ts",
    "test:setup": "bun --env-file=.env.test run db:setup"
  },
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.985.0",
    "@elastic/elasticsearch": "^8.17.0",
    "@nahkies/typescript-express-runtime": "0.22.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.211.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-metrics": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "backend": "file:",
    "better-auth": "^1.4.18",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.1",
    "pg": "^8.17.1",
    "pg-boss": "^12.9.0",
    "pino": "^10.2.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "request-ip": "^3.3.0",
    "typeorm": "^0.3.20",
    "uuid": "^13.0.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@nahkies/openapi-code-generator": "0.22.0",
    "@redocly/cli": "^2.14.5",
    "@scalar/cli": "^1.4.3",
    "@types/bun": "^1.3.6",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/pino": "^7.0.4",
    "@types/recursive-readdir": "^2.2.4",
    "@types/request-ip": "^0.0.41",
    "@types/supertest": "^6.0.3",
    "@usebruno/cli": "^3.0.2",
    "@usebruno/converters": "^0.16.0",
    "chokidar-cli": "^3.0.0",
    "js-yaml": "^4.1.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "yaml": "^2.8.2"
  }
}
