meta {
  name: Fetch context for a sentence
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/v1/search/media/context
  body: json
  auth: inherit
}

body:json {
  {
    "mediaId": 110316,
    "episode": 5,
    "segmentPosition": 1133,
    "limit": 5
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
