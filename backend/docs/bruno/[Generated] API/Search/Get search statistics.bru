meta {
  name: Get search statistics
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/v1/search/stats
  body: json
  auth: bearer
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "query": "彼女",
    "category": [
      "ANIME",
      "JDRAMA"
    ],
    "exactMatch": false,
    "minLength": 10,
    "maxLength": 50,
    "excludedMediaIds": [],
    "status": [
      "ACTIVE"
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
