meta {
  name: Get search statistics
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/v1/search/stats
  body: json
  auth: bearer
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "query": {
      "search": "彼女",
      "exactMatch": false
    },
    "filters": "",
    "include": []
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
