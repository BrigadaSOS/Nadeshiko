meta {
  name: Search by multiple words
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/v1/search/words
  body: json
  auth: bearer
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "query": {
      "words": [
        "彼女",
        "私"
      ],
      "exactMatch": false
    },
    "filters": "",
    "include": [],
    "words": [
      "彼女",
      "私"
    ],
    "exactMatch": false
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
