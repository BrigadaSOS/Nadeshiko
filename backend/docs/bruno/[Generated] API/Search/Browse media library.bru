meta {
  name: Browse media library
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/v1/media/browse?size=20&query=steins&type=anime
  body: none
  auth: bearer
}

params:query {
  size: 20
  cursor:
  query: steins
  type: anime
}

auth:bearer {
  token: {{apiKey}}
}

settings {
  encodeUrl: true
  timeout: 0
}
