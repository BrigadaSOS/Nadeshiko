meta {
  name: Get single episode
  type: http
  seq: 29
}

get {
  url: {{baseUrl}}/v1/media/:mediaId/episodes/:episodeNumber?mediaId=V1StGXR8_Z5d&episodeNumber=1
  body: none
  auth: bearer
}

params:query {
  mediaId: V1StGXR8_Z5d
  episodeNumber: 1
}

auth:bearer {
  token: {{apiKey}}
}

settings {
  encodeUrl: true
  timeout: 0
}
