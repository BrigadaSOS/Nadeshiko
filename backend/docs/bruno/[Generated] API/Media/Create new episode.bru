meta {
  name: Create new episode
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/v1/media/:mediaId/episodes
  body: json
  auth: bearer
}

params:query {
  mediaId:
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "anilistEpisodeId": 0,
    "titleEn": "",
    "titleRomaji": "",
    "titleJa": "",
    "description": "",
    "airedAt": "",
    "lengthSeconds": 0,
    "thumbnailUrl": "",
    "episodeNumber": 0
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
