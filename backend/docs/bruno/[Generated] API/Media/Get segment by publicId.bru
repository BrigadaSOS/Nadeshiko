meta {
  name: Get segment by publicId
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/v1/media/segments/:uuid?include=ratingAnalysis&include=posAnalysis&include=hashedId&include=storageBasePath&include=storage
  body: none
  auth: bearer
}

params:query {
  uuid:
  include: ratingAnalysis
  include: posAnalysis
  include: hashedId
  include: storageBasePath
  include: storage
}

auth:bearer {
  token: {{apiKey}}
}

settings {
  encodeUrl: true
  timeout: 0
}
