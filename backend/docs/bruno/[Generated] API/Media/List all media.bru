meta {
  name: List all media
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/v1/media?limit=20&category=ANIME&query=steins&include=media
  body: none
  auth: bearer
}

params:query {
  limit: 20
  cursor:
  category: ANIME
  query: steins
  include: media
}

auth:bearer {
  token: {{apiKey}}
}

settings {
  encodeUrl: true
  timeout: 0
}
