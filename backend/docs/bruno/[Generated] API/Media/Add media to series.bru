meta {
  name: Add media to series
  type: http
  seq: 16
}

post {
  url: {{baseUrl}}/v1/media/series/:id/media
  body: json
  auth: bearer
}

params:query {
  id:
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "mediaId": "abc123def456",
    "position": 1
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
