meta {
  name: List segments for an episode
  type: http
  seq: 29
}

get {
  url: {{baseUrl}}/v1/media/:mediaId/episodes/:episodeNumber/segments?mediaId=V1StGXR8_Z5d&episodeNumber=1&take=50&cursor=1000
  body: none
  auth: bearer
}

params:query {
  mediaId: V1StGXR8_Z5d
  episodeNumber: 1
  take: 50
  cursor: 1000
}

auth:bearer {
  token: {{apiKey}}
}

settings {
  encodeUrl: true
  timeout: 0
}
