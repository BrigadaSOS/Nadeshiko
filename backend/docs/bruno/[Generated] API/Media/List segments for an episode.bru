meta {
  name: List segments for an episode
  type: http
  seq: 28
}

get {
  url: {{baseUrl}}/v1/media/:mediaId/episodes/:episodeNumber/segments
  body: none
  auth: bearer
}

params:query {
  mediaId:
  episodeNumber:
  take:
  cursor:
}

auth:bearer {
  token: {{apiKey}}
}

settings {
  encodeUrl: true
  timeout: 0
}
