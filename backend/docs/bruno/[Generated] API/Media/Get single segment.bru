meta {
  name: Get single segment
  type: http
  seq: 32
}

get {
  url: {{baseUrl}}/v1/media/:mediaId/episodes/:episodeNumber/segments/:id
  body: none
  auth: bearer
}

params:query {
  mediaId:
  episodeNumber:
  id:
}

auth:bearer {
  token: {{apiKey}}
}

settings {
  encodeUrl: true
  timeout: 0
}
