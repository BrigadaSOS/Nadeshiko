meta {
  name: Get single segment
  type: http
  seq: 35
}

get {
  url: {{baseUrl}}/v1/media/:mediaId/episodes/:episodeNumber/segments/:id?mediaId=V1StGXR8_Z5d&episodeNumber=1&id=12345
  body: none
  auth: bearer
}

params:query {
  mediaId: V1StGXR8_Z5d
  episodeNumber: 1
  id: 12345
}

auth:bearer {
  token: {{apiKey}}
}

settings {
  encodeUrl: true
  timeout: 0
}
