meta {
  name: Update media position in series
  type: http
  seq: 20
}

patch {
  url: {{baseUrl}}/v1/media/series/:id/media/:mediaId?id=V1StGXR8_Z5d&mediaId=abc123def456
  body: json
  auth: bearer
}

params:query {
  id: V1StGXR8_Z5d
  mediaId: abc123def456
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "position": 2
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
