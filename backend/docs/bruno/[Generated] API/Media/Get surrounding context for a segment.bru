meta {
  name: Get surrounding context for a segment
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/v1/media/segments/:uuid/context
  body: none
  auth: bearer
}

params:query {
  uuid:
  take:
  contentRating:
  include:
}

auth:bearer {
  token: {{apiKey}}
}

settings {
  encodeUrl: true
  timeout: 0
}
