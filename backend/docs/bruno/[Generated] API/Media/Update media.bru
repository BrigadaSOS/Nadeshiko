meta {
  name: Update media
  type: http
  seq: 10
}

patch {
  url: {{baseUrl}}/v1/media/:id
  body: json
  auth: bearer
}

params:query {
  id:
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "anilistId": 0,
    "nameJa": "",
    "nameRomaji": "",
    "nameEn": "",
    "airingFormat": "",
    "airingStatus": "",
    "genres": [],
    "storage": "",
    "startDate": "",
    "endDate": "",
    "category": "",
    "version": "",
    "hashSalt": "",
    "studio": "",
    "seasonName": "",
    "seasonYear": 0,
    "characters": [
      {
        "id": 0,
        "nameJa": "",
        "nameEn": "",
        "imageUrl": "",
        "role": "",
        "seiyuuId": 0,
        "seiyuuNameJa": "",
        "seiyuuNameEn": "",
        "seiyuuImageUrl": ""
      }
    ],
    "lists": [
      {
        "listId": 0,
        "listName": "",
        "listType": "",
        "listVisibility": "",
        "position": 0
      }
    ],
    "segmentCount": 0
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
