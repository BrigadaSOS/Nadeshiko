meta {
  name: Update media
  type: http
  seq: 21
}

patch {
  url: {{baseUrl}}/v1/media/:id
  body: json
  auth: bearer
}

params:query {
  id:
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "externalIds": {
      "anilist": "",
      "imdb": "",
      "tvdb": ""
    },
    "nameJa": "",
    "nameRomaji": "",
    "nameEn": "",
    "airingFormat": "",
    "airingStatus": "",
    "genres": [],
    "storage": "",
    "startDate": "",
    "endDate": "",
    "category": "",
    "version": "",
    "hashSalt": "",
    "studio": "",
    "seasonName": "",
    "seasonYear": 0,
    "storageBasePath": "",
    "characters": [
      {
        "externalIds": {},
        "nameJa": "",
        "nameEn": "",
        "imageUrl": "",
        "role": "",
        "seiyuu": {
          "externalIds": {},
          "nameJa": "",
          "nameEn": "",
          "imageUrl": ""
        }
      }
    ],
    "segmentCount": 0
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
