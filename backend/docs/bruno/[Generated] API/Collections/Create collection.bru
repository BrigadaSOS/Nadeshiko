meta {
  name: Create collection
  type: http
  seq: 45
}

post {
  url: {{baseUrl}}/v1/collections
  body: json
  auth: none
}

body:json {
  {
    "name": "My Study List",
    "visibility": "PRIVATE"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
