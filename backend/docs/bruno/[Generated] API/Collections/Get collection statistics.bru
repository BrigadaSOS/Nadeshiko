meta {
  name: Get collection statistics
  type: http
  seq: 59
}

get {
  url: {{baseUrl}}/v1/collections/:id/stats
  body: none
  auth: none
}

params:query {
  id:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
