meta {
  name: Get collection statistics
  type: http
  seq: 52
}

get {
  url: {{baseUrl}}/v1/collections/:collectionPublicId/stats?collectionPublicId=V1StGXR8_Z5d
  body: none
  auth: none
}

params:query {
  collectionPublicId: V1StGXR8_Z5d
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
