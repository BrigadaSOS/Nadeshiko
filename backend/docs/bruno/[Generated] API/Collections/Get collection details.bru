meta {
  name: Get collection details
  type: http
  seq: 46
}

get {
  url: {{baseUrl}}/v1/collections/:id
  body: none
  auth: none
}

params:query {
  id:
  cursor:
  page:
  limit:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
