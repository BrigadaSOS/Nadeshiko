meta {
  name: Remove segment from collection
  type: http
  seq: 53
}

delete {
  url: {{baseUrl}}/v1/collections/:id/segments/:uuid
  body: none
  auth: none
}

params:query {
  id:
  uuid:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
