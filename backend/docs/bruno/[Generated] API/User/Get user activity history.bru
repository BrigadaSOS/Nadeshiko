meta {
  name: Get user activity history
  type: http
  seq: 38
}

get {
  url: {{baseUrl}}/v1/user/activity?limit=20
  body: none
  auth: none
}

params:query {
  cursor:
  limit: 20
  activityType:
  date:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
