meta {
  name: Get activity heatmap data
  type: http
  seq: 39
}

get {
  url: {{baseUrl}}/v1/user/activity/heatmap?days=365
  body: none
  auth: none
}

params:query {
  days: 365
  activityType:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
