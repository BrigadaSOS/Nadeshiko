meta {
  name: Unenroll from a lab feature
  type: http
  seq: 39
}

delete {
  url: {{baseUrl}}/v1/user/labs/:key
  body: none
  auth: none
}

params:query {
  key:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
