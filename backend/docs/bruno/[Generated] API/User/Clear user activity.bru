meta {
  name: Clear user activity
  type: http
  seq: 44
}

delete {
  url: {{baseUrl}}/v1/user/activity
  body: none
  auth: none
}

params:query {
  activityType:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
