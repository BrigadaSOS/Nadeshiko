meta {
  name: Delete all activity for a specific date
  type: http
  seq: 42
}

delete {
  url: {{baseUrl}}/v1/user/activity/date/:date
  body: none
  auth: none
}

params:query {
  date:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
