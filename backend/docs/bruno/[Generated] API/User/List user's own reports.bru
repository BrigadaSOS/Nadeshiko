meta {
  name: List user's own reports
  type: http
  seq: 34
}

get {
  url: {{baseUrl}}/v1/user/reports?limit=20
  body: none
  auth: none
}

params:query {
  cursor:
  limit: 20
  status:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
