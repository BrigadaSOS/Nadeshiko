meta {
  name: Clear admin impersonation
  type: http
  seq: 65
}

delete {
  url: {{baseUrl}}/v1/admin/impersonation
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
