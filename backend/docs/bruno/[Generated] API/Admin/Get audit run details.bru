meta {
  name: Get audit run details
  type: http
  seq: 84
}

get {
  url: {{baseUrl}}/v1/admin/media/audits/runs/:id
  body: none
  auth: none
}

params:query {
  id:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
