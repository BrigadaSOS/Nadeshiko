meta {
  name: Delete report and its group
  type: http
  seq: 58
}

delete {
  url: {{baseUrl}}/v1/admin/reports/:reportId
  body: none
  auth: none
}

params:query {
  reportId:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
