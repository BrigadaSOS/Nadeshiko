meta {
  name: List past audit runs
  type: http
  seq: 76
}

get {
  url: {{baseUrl}}/v1/admin/media/audits/runs?take=20
  body: none
  auth: none
}

params:query {
  auditName:
  cursor:
  take: 20
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
