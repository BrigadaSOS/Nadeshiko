meta {
  name: Update report
  type: http
  seq: 58
}

patch {
  url: {{baseUrl}}/v1/admin/reports/:reportId
  body: json
  auth: none
}

params:query {
  reportId:
}

body:json {
  {
    "status": "OPEN",
    "adminNotes": "Confirmed wrong translation, will fix"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
