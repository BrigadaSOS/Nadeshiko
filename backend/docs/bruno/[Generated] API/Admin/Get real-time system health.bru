meta {
  name: Get real-time system health
  type: http
  seq: 66
}

get {
  url: {{baseUrl}}/v1/admin/dashboard/system
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
