meta {
  name: Batch update reports
  type: http
  seq: 75
}

patch {
  url: {{baseUrl}}/v1/admin/reports/batch
  body: json
  auth: none
}

body:json {
  {
    "ids": [
      1,
      2,
      3
    ],
    "status": "IGNORED",
    "adminNotes": ""
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
