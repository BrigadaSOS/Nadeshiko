meta {
  name: Run media audit
  type: http
  seq: 75
}

post {
  url: {{baseUrl}}/v1/admin/media/audits/:name/run?category=ANIME&category=JDRAMA
  body: none
  auth: none
}

params:query {
  name:
  category: ANIME
  category: JDRAMA
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
