meta {
  name: Update a report
  type: http
  seq: 72
}

patch {
  url: {{baseUrl}}/v1/admin/reports/:id
  body: json
  auth: none
}

params:query {
  id:
}

body:json {
  {
    "status": "",
    "adminNotes": ""
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
