meta {
  name: Get activity analytics
  type: http
  seq: 66
}

get {
  url: {{baseUrl}}/v1/admin/dashboard/activity
  body: none
  auth: none
}

params:query {
  days:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
