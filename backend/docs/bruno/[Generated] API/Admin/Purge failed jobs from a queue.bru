meta {
  name: Purge failed jobs from a queue
  type: http
  seq: 67
}

delete {
  url: {{baseUrl}}/v1/admin/queues/:queueName/purge
  body: none
  auth: none
}

params:query {
  queueName:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
