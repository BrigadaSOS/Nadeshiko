meta {
  name: Update media audit config
  type: http
  seq: 84
}

patch {
  url: {{baseUrl}}/v1/admin/media/audits/:name
  body: json
  auth: none
}

params:query {
  name:
}

body:json {
  {
    "threshold": {},
    "enabled": false
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
