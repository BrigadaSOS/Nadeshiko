meta {
  name: Get collection statistics (GET)
  type: http
  seq: 67
}

get {
  url: {{baseUrl}}/v1/admin/dashboard/collections
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
