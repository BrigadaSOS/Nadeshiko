meta {
  name: Create or update announcement
  type: http
  seq: 66
}

put {
  url: {{baseUrl}}/v1/admin/announcement
  body: json
  auth: none
}

body:json {
  {
    "message": "Scheduled maintenance tonight from 2-4 AM UTC.",
    "type": "INFO",
    "active": true
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
