meta {
  name: Get queue statistics
  type: http
  seq: 63
}

get {
  url: {{baseUrl}}/v1/admin/queues/stats
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
