meta {
  name: Run a media audit
  type: http
  seq: 72
}

post {
  url: {{baseUrl}}/v1/admin/media/audits/:name/run
  body: none
  auth: none
}

params:query {
  name:
  category:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
