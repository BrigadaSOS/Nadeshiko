meta {
  name: Get detailed queue information
  type: http
  seq: 62
}

get {
  url: {{baseUrl}}/v1/admin/queues/:queueName
  body: none
  auth: none
}

params:query {
  queueName:
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
