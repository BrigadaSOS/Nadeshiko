meta {
  name: List all lists
  type: http
  seq: 26
}

get {
  url: {{baseUrl}}/v1/lists?visibility=public&type=SERIES&userId=1&mediaId=12345
  body: none
  auth: bearer
}

params:query {
  visibility: public
  type: SERIES
  userId: 1
  mediaId: 12345
}

auth:bearer {
  token: {{apiKey}}
}

settings {
  encodeUrl: true
  timeout: 0
}
