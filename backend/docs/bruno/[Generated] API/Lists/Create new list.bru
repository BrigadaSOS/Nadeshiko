meta {
  name: Create new list
  type: http
  seq: 26
}

post {
  url: {{baseUrl}}/v1/lists
  body: json
  auth: bearer
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "name": "My Watchlist",
    "type": "CUSTOM",
    "userId": 1,
    "visibility": "PUBLIC"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
