meta {
  name: Sign in with email and password
  type: http
  seq: 99
}

post {
  url: {{baseUrl}}/v1/auth/sign-in/email
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
