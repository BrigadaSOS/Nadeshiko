meta {
  name: Delete a user and all their sessions and accounts. Cannot be undone.
  type: http
  seq: 94
}

post {
  url: {{baseUrl}}/v1/auth/admin/remove-user
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
