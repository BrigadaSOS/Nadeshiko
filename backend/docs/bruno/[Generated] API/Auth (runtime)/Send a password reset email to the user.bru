meta {
  name: Send a password reset email to the user
  type: http
  seq: 118
}

post {
  url: {{baseUrl}}/v1/auth/request-password-reset
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
