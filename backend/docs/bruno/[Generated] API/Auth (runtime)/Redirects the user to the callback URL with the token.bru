meta {
  name: Redirects the user to the callback URL with the token
  type: http
  seq: 95
}

get {
  url: {{baseUrl}}/v1/auth/reset-password/:token
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
