meta {
  name: Sign in with magic link
  type: http
  seq: 101
}

post {
  url: {{baseUrl}}/v1/auth/sign-in/magic-link
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
