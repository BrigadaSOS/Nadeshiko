meta {
  name: Verify magic link
  type: http
  seq: 110
}

get {
  url: {{baseUrl}}/v1/auth/magic-link/verify
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
