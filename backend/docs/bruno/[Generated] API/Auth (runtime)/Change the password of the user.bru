meta {
  name: Change the password of the user
  type: http
  seq: 88
}

post {
  url: {{baseUrl}}/v1/auth/change-password
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
