meta {
  name: Update the current session
  type: http
  seq: 102
}

post {
  url: {{baseUrl}}/v1/auth/update-session
  body: none
  auth: none
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const sessionToken = bru.getEnvVar("sessionToken");
  if (sessionToken) {
    req.setHeader("Cookie", "nadeshiko.session_token=" + sessionToken);
  }
}
