{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["dom", "es2021", "esnext.asynciterable"]
  },
  "include": [
    "main.ts",
    "app/**/*.ts",
    "bin/**/*.ts",
    "config/**/*.ts",
    "db/**/*.ts",
    "lib/**/*.ts",
    "generated/**/*.ts"
  ],
  "exclude": ["tests", "docs", "prod", "node_modules", "client"]
}
