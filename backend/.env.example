ENVIRONMENT=local
R2_BASE_URL=https://cdn.nadeshiko.co
LOCAL_BASE_URL=/media
MEDIA_FILES_PATH=../media
PORT=5000
UUID_NAMESPACE="a44410bd-243c-48eb-9088-38304d6f5328"

# Database
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_PASSWORD=admin
POSTGRES_USER=nadeshiko
POSTGRES_PASSWORD=nadeshiko
POSTGRES_DB=nadedb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_SLOW_QUERY_THRESHOLD_MS=200

# Elasticsearch
# To reset the elastic user password, run:
# docker exec -it nadeshiko-elasticsearch /usr/share/elasticsearch/bin/elasticsearch-reset-password -u elastic
ELASTICSEARCH_ADMIN_USER=elastic
ELASTICSEARCH_ADMIN_PASSWORD=admin
ELASTICSEARCH_USER=nadeshiko-dev
ELASTICSEARCH_PASSWORD=nade-admin
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_INDEX=nadedb_local

# API / Auth
USERNAME_API_NADEDB=admin
PASSWORD_API_NADEDB=admin
EMAIL_API_NADEDB=admin@admin.com
BETTER_AUTH_SECRET=random-better-auth-secret
ALLOWED_WEBSITE_URLS=http://localhost:3000
API_KEY_MASTER=nade_master-api-key
E2E_USER_PASSWORD=nadeshiko-e2e-local
SERVICE_API_KEY_IDS=
API_KEY_RATE_LIMIT_WINDOW_MS=60000
API_KEY_RATE_LIMIT_MAX=150
BASE_URL=http://localhost:3000

# OAuth
ID_OAUTH_GOOGLE=""
SECRET_OAUTH_GOOGLE=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Email (SES)
