KAMAL_REGISTRY_PASSWORD=$(gh auth token)

SECRETS=$(kamal secrets fetch --adapter aws_ssm_parameter_store --account nadeshiko-prod --from /nadeshiko/prod DISCORD_BOT_TOKEN DISCORD_API_KEY_MASTER)

DISCORD_BOT_TOKEN=$(kamal secrets extract /nadeshiko/prod/DISCORD_BOT_TOKEN $SECRETS)
DISCORD_API_KEY_MASTER=$(kamal secrets extract /nadeshiko/prod/DISCORD_API_KEY_MASTER $SECRETS)
