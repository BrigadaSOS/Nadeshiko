{
  "name": "nadeshiko-discord",
  "version": "2.1.1",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/bot.ts",
    "start": "node --import tsx src/bot.ts",
    "register": "node --import tsx src/register.ts",
