#!/bin/sh

# Block pushes to main that fail lint or typecheck.

remote="$1"

pushing_to_main=false
while read local_ref local_oid remote_ref remote_oid; do
  case "$remote_ref" in
    refs/heads/main) pushing_to_main=true ;;
  esac
done

if [ "$pushing_to_main" = false ]; then
  exit 0
fi

echo "Pushing to main -- running lint and typecheck..."

cd "$(git rev-parse --show-toplevel)" || exit 1

echo "=> Backend: lint"
(cd backend && bun run lint:code) || { echo "Backend lint failed"; exit 1; }

echo "=> Backend: typecheck"
(cd backend && bun run typecheck) || { echo "Backend typecheck failed"; exit 1; }

echo "=> Frontend: lint"
(cd frontend && bun run lint) || { echo "Frontend lint failed"; exit 1; }

echo "=> Frontend: typecheck"
(cd frontend && bun run typecheck) || { echo "Frontend typecheck failed"; exit 1; }

echo "All checks passed."
