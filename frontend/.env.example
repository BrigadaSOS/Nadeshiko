NUXT_PUBLIC_ENVIRONMENT=local
NUXT_BACKEND_INTERNAL_URL=http://localhost:5000
NUXT_MEDIA_FILES_PATH=../media
NUXT_NADESHIKO_API_KEY=nade_master-api-key
# Must match the backend's INTERNAL_PROXY_SECRET (lets the backend rate limiter
# exempt traffic proxied through this frontend).
NUXT_INTERNAL_PROXY_SECRET=internal-proxy-secret
NUXT_FALLBACK_RATE_LIMIT_WINDOW_MS=60000
NUXT_FALLBACK_RATE_LIMIT_MAX_REQUESTS=300
NUXT_RATE_LIMIT_V1_AUTH_MAX=30
NUXT_RATE_LIMIT_V1_API_MAX=120
NUXT_RATE_LIMIT_HTML_MAX=60
