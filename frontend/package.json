{
  "name": "nuxt-app",
  "version": "2.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --bun nuxt build",
    "dev": "bun --bun nuxt dev | pino-pretty",
    "lint": "biome lint .",
    "typecheck": "bun --bun nuxt typecheck",
    "lint:fix": "biome lint . --write",
    "format": "biome format . --write",
    "preview": "bun --bun nuxt preview",
    "postinstall": "bun --bun nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:dev": "bash scripts/run-e2e-remote.sh dev",
    "test:e2e:prod": "bash scripts/run-e2e-remote.sh prod",
    "test:e2e:local": "E2E_BASE_URL=http://localhost:3000 playwright test --config=e2e/playwright.config.ts",
    "setup": "bun run bin/setup.ts"
  },
  "dependencies": {
    "@brigadasos/nadeshiko-sdk": "2.0.1-internal.5a1af3c",
    "@mdi/js": "^7.4.47",
    "@nuxtjs/i18n": "^10.2.1",
    "@nuxtjs/seo": "^3.4.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-metrics": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^10.40.0",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "nuxt-security": "^2.5.1",
    "nuxt-umami": "^3.2.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pino": "^10.3.0",
    "vue-chartjs": "^5.3.3",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "overrides": {
    "@vue/devtools-kit": "7.7.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/critters": "^0.9.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.1.35",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^14.1.0",
    "@vueuse/nuxt": "^14.1.0",
    "happy-dom": "^20.8.4",
    "nuxt": "^4.2.2",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vitest": "^4.1.0"
  }
}
