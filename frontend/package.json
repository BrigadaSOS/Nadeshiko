{
  "name": "nuxt-app",
  "version": "2.1.1",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "bun --bun nuxt dev | pino-pretty",
    "lint": "biome check .",
    "typecheck": "vue-tsc --noEmit",
    "lint:fix": "biome check . --write",
    "preview": "bun --bun nuxt preview",
    "postinstall": "bun --bun nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:dev": "bash scripts/run-e2e-remote.sh dev",
    "test:e2e:prod": "bash scripts/run-e2e-remote.sh prod",
    "test:e2e:local": "E2E_BASE_URL=http://localhost:3000 playwright test --config=e2e/playwright.config.ts",
    "setup": "bun run bin/setup.ts"
  },
  "dependencies": {
    "@brigadasos/nadeshiko-sdk": "2.1.0-internal.b789c9e",
    "@grafana/faro-transport-otlp-http": "^2.6.3",
    "@grafana/faro-web-sdk": "^2.3.1",
    "@grafana/faro-web-tracing": "^2.3.1",
    "@mdi/js": "^7.4.47",
    "@nuxtjs/i18n": "^10.2.1",
    "@nuxtjs/seo": "5.1.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation-pino": "^0.64.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.31.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@pinia/nuxt": "^0.11.3",
    "@posthog/nuxt": "^1.7.35",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.3",
    "nuxt-security": "^2.5.1",
    "nuxt-umami": "^3.2.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pino": "^10.3.0",
    "shiki": "^4.0.0",
    "vue-toastification": "^2.0.0-rc.5",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@vue/devtools-kit": "7.7.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/critters": "^0.9.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.1.35",
    "@vue/test-utils": "^2.4.10",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "happy-dom": "^20.8.4",
    "nuxt": "^4.4.5",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.6"
  }
}
