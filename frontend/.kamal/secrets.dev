KAMAL_REGISTRY_PASSWORD=$(gh auth token)

SECRETS=$(kamal secrets fetch --adapter aws_ssm_parameter_store --account nadeshiko-dev --from /nadeshiko/dev NUXT_NADESHIKO_API_KEY SENTRY_FRONTEND_DSN SENTRY_AUTH_TOKEN)

NUXT_NADESHIKO_API_KEY=$(kamal secrets extract /nadeshiko/dev/NUXT_NADESHIKO_API_KEY $SECRETS)
SENTRY_FRONTEND_DSN=$(kamal secrets extract /nadeshiko/dev/SENTRY_FRONTEND_DSN $SECRETS)
SENTRY_AUTH_TOKEN=$(kamal secrets extract /nadeshiko/dev/SENTRY_AUTH_TOKEN $SECRETS)
